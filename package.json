{
  "author": "RedisGrafana",
  "description": "Redis Application for Grafana",
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "8.3.4",
    "@grafana/runtime": "8.3.4",
    "@grafana/ui": "8.3.4",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/tsconfig": "^2.0.1",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^12",
    "@testing-library/user-event": "^14",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^17",
    "@types/react-dom": "^17",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.1.0",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.6.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.0",
    "semver": "^7.7.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-node": "^10.9.0",
    "tslib": "^2",
    "typescript": "5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "name": "redis-app",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "format": "prettier --write \"**\"",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "start": "docker-compose up",
    "start:dev": "docker-compose -f docker-compose/dev.yml pull && docker-compose -f docker-compose/dev.yml up",
    "start:master": "docker-compose -f docker-compose/master.yml pull && docker-compose -f docker-compose/master.yml up",
    "stop": "docker-compose down",
    "stop:dev": "docker-compose -f docker-compose/dev.yml down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "validate": "bash scripts/validate-plugin.sh",
    "upgrade": "yarn upgrade --latest"
  },
  "version": "2.3.2",
  "packageManager": "yarn@1.22.22"
}
